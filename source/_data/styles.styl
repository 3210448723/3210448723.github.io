.content-wrap {
  max-width: 900px;
}

.posts-expand .post-body {
  font-size: 16px;
  line-height: 1.95;
  letter-spacing: 0.2px;
}

.posts-expand .post-title {
  font-weight: 600;
  letter-spacing: 0.3px;
}

.post-body p {
  margin: 0 0 1.15em 0;
}
.post-body ul, .post-body ol {
  margin: 0.6em 0 1.2em 1.4em;
}

blockquote {
  border-left: 4px solid #d0d7de;
  background: #f8fafc;
  border-radius: 6px;
  padding: 12px 16px;
  color: #4b5563;
}

.highlight {
  border-radius: 10px;
  box-shadow: none;
}
code {
  border-radius: 4px;
  padding: 0.15em 0.35em;
}
